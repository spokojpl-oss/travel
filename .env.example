# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Aplikacja (produkcja: https://travel.mpai.pl)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (opcjonalne, Etap 3+) – emaile z dostępem do /api/admin/initial-scrape
ADMIN_EMAILS=twoj-email@example.com

# Etap 4 – Google Places + Claude (server-side)
GOOGLE_PLACES_API_KEY=
# Google Maps — mapa interaktywna (klient) + Directions API (serwer, może być ten sam klucz)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=

# Etap 5 – Travelpayouts (Aviasales + Booking)
# Token API: panel → Programs → Aviasales → Tools → API → „API token”
TRAVELPAYOUTS_TOKEN=
# Partner ID (marker): ten sam panel → „Partner ID (Marker)” — NIE mylić z ID projektu Drive (np. 539712)
TRAVELPAYOUTS_MARKER_AVIASALES=
TRAVELPAYOUTS_MARKER_BOOKING=
# Travelpayouts Drive — skrypt w src/components/analytics/TravelpayoutsDriveScript.tsx (head)
# ID projektu Drive (539712) ≠ TRAVELPAYOUTS_MARKER_AVIASALES

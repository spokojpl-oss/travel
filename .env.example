# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Aplikacja (produkcja: https://travel.mpai.pl)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (opcjonalne, Etap 3+) – emaile z dostępem do /api/admin/initial-scrape
ADMIN_EMAILS=twoj-email@example.com

# Etap 4 – Google Places (wyszukiwanie miejsc, nie mapa interaktywna) + Claude
GOOGLE_PLACES_API_KEY=
# Opcjonalnie: Google Maps JavaScript API — na razie mapa używa OpenStreetMap + OSRM
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=

# Etap 5 – Travelpayouts (Aviasales + Booking marker na przyszłość)
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER_AVIASALES=
TRAVELPAYOUTS_MARKER_BOOKING=
